# 生产环境变量模板
# 复制此文件为 .env.production 并填写实际值（本地开发时）
# CI/CD 环境通过 GitHub Secrets 自动注入

# API 基础路径（生产环境前后端同域，使用相对路径）
VITE_API_BASE_URL=/api

# Coze API 配置（用于帖子改写工作流）
# 从 Coze 平台获取：https://www.coze.cn/
VITE_COZE_API_KEY=your_coze_api_key_here
VITE_COZE_WORKFLOW_ID=your_workflow_id_here
VITE_COZE_APP_ID=your_app_id_here
